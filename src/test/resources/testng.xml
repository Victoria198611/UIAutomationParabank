<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Parabank Suite" verbose="1" parallel="false">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="UI Tests">
        <classes>
            <class name="com.victoria.parabank.tests.LoginTests"/>
            <class name="com.victoria.parabank.tests.RegisterTests"/>
            <class name="com.victoria.parabank.tests.AccountsTests"/>
            <class name="com.victoria.parabank.tests.OpenAccountTests"/>
            <class name="com.victoria.parabank.tests.TransferTests"/>
            <class name="com.victoria.parabank.tests.BillPayTests"/>
            <class name="com.victoria.parabank.tests.HomeTest"/>
            <class name="com.victoria.parabank.tests.UpdateProfileTest"/>
        </classes>
    </test>

</suite>